{
  "name": "penclaw",
  "version": "0.1.0",
  "description": "AI-powered penetration testing CLI for static analysis and AI triage.",
  "type": "module",
  "bin": {
    "penclaw": "./dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/cli/index.js",
    "clean": "rm -rf dist",
    "dev": "tsx src/cli/index.ts",
    "prepare": "npm run build"
  },
  "keywords": [
    "security",
    "pentest",
    "cli",
    "semgrep",
    "trivy",
    "ai"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "cosmiconfig": "^9.0.1",
    "fast-glob": "^3.3.3",
    "ignore": "^7.0.5",
    "openai": "^6.32.0",
    "ora": "^9.3.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
